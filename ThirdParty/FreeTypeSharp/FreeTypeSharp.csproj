<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<RootNamespace>FreeTypeSharp</RootNamespace>
		<AssemblyName>FreeTypeSharp</AssemblyName>
		<BaseOutputPath>$(SolutionDir)bin</BaseOutputPath>
		<TargetFramework>net8.0</TargetFramework>
		<Configurations>Debug;Release;Debug-Android</Configurations>
		<Description>A modern cross-platform managed FreeType2 library.</Description>
		<PackageTags>freetype2;.net6.0;</PackageTags>
		<PackageId>FreeTypeSharp</PackageId>
		<Configurations>Debug;Release;Debug-Android-Profiler</Configurations>
		<Platforms>x64</Platforms>
	</PropertyGroup>
<!--	<PropertyGroup Condition="'$(TargetFramework)' == 'net6.0-ios' or '$(TargetFramework)' == 'net6.0-tvos'">-->
<!--		<IsBindingProject>true</IsBindingProject>-->
<!--		<SupportedOSPlatformVersion>11.0</SupportedOSPlatformVersion>-->
<!--	</PropertyGroup>-->

	<PropertyGroup Condition="'$(Configuration)'=='Debug-Android' or '$(Configuration)'=='Debug-Android-Profiler' or '$(Configuration)'=='Release-Android'">
		<TargetFramework>net8.0-android</TargetFramework>
		<DefineConstants>$(DefineConstants);ANDROID</DefineConstants>
	</PropertyGroup>
	
	<ItemGroup Condition="'$(TargetFramework)'=='net8.0'">
		<Content Include="$(SolutionDir)\dependencies\runtimes\win-x64\native\freetype.dll">
			<Link>runtimes\win-x64\native\freetype.dll</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>

		<Content Include="$(SolutionDir)\dependencies\runtimes\osx-x64\native\libfreetype.dylib">
			<Link>runtimes\osx\native\libfreetype.dylib</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>

		<Content Include="$(SolutionDir)\dependencies\runtimes\linux-x64\native\libfreetype.so">
			<Link>runtimes\linux-x64\native\libfreetype.so</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)'=='net8.0-android'">
		<AndroidNativeLibrary Include="$(SolutionDir)dependencies\runtimes\android\x86_64\libfreetype.so">
			<Link>libs/x86_64/libfreetype.so</Link>
			<Abi>x86_64</Abi>
		</AndroidNativeLibrary>
		<AndroidNativeLibrary Include="$(SolutionDir)dependencies\runtimes\android\x86\libfreetype.so">
			<Link>libs/x86/libfreetype.so</Link>
			<Abi>x86</Abi>
		</AndroidNativeLibrary>
		<AndroidNativeLibrary Include="$(SolutionDir)dependencies\runtimes\android\armeabi-v7a\libfreetype.so">
			<Link>libs/armeabi-v7a/libfreetype.so</Link>
			<Abi>armeabi-v7a</Abi>
		</AndroidNativeLibrary>
		<AndroidNativeLibrary Include="$(SolutionDir)dependencies\runtimes\android\arm64-v8a\libfreetype.so">
			<Link>libs/arm64-v8a/libfreetype.so</Link>
			<Abi>arm64-v8a</Abi>
		</AndroidNativeLibrary>
	</ItemGroup>
