<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;</TargetFrameworks>
    <AssemblyVersion>0.8.0</AssemblyVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>ImPlot.NET</AssemblyName>
    <Authors>Eric Mellino</Authors>
    <Description>A .NET wrapper for the ImPlot library.</Description>
    <RootNamespace>ImPlotNET</RootNamespace>
    <Configurations>Debug;Release;Debug-Linux;Debug-Profiler;Release-Profiler;Debug-Android;Debug-Android-Profiler;Debug-Web</Configurations>
    <Platforms>x64</Platforms>
  </PropertyGroup>

  <Import Project="$(SolutionDir)ProjectBuildProperties.targets"/>
  
  <ItemGroup>
    <PackageReference Include="System.Numerics.Vectors" Version="4.4.0" />
    <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="4.4.0" />
    <PackageReference Include="System.Buffers" Version="4.4.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\ImGui.NET\ImGui.NET.csproj" />
  </ItemGroup>
</Project>
