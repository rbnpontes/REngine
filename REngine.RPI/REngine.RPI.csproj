		</None>
		<None Update="Assets\Fonts\DroidSans.ttf">
		  <CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Update="Assets\Fonts\Roboto-Medium.ttf">
		  <CopyToOutputDirectory>Always</CopyToOutputDirectory>
		</None>
		<None Update="Assets\Shaders\copy_rt_ps.hlsl">
