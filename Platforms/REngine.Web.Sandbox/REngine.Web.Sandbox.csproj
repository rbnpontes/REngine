<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <RunAOTCompilation>true</RunAOTCompilation>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <PublishTrimmed>true</PublishTrimmed>
        <TrimMode>full</TrimMode>
        <WasmStripILAfterAOT>true</WasmStripILAfterAOT>
    </PropertyGroup>
    
    <Import Project="$(SolutionDir)ProjectBuildProperties.targets"/>
    <PropertyGroup>
        <RuntimeIdentifier>browser-wasm</RuntimeIdentifier>
        <PlatformTarget>AnyCPU</PlatformTarget>
    </PropertyGroup>
    
    <ItemGroup>
        <WasmExtraFilesToDeploy Include="index.html"/>
        <WasmExtraFilesToDeploy Include="*.js"/>
    </ItemGroup>
    
    <Import Project="$(SolutionDir)WebBuildProperties.targets"/>
    <Import Project="$(SolutionDir)WebAssetsBuildProperties.targets"/>
    
    <ItemGroup>
      <ProjectReference Include="..\..\REngine.Contents\REngine.Contents.csproj" />
      <ProjectReference Include="..\..\REngine.RHI.Web.Driver\REngine.RHI.Web.Driver.csproj" />
      <ProjectReference Include="..\REngine.Core.Web\REngine.Core.Web.csproj" />
    </ItemGroup>
</Project>
